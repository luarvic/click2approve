{
  "AllowedHosts": "*",
  "AllowedOrigins": [
    "http://click2approve.com",
    "https://click2approve.com",
    "http://www.click2approve.com",
    "https://www.click2approve.com"
  ],
  "Authentication": {
    "BearerTokenExpirationInMinutes": 60,
    "RefreshTokenExpirationInDays": 7
  },
  "AzureEmailCommunication": {
    "ConnectionString": "",
    "MaxRetryAttempts": 3,
    "RetryDelaySeconds": 5
  },
  "ConnectionStrings": {
    "Default": ""
  },
  "Email": {
    "FromEmailAddress": "",
    "Host": "",
    "IsEnabled": true,
    "Password": "",
    "Port": 0,
    "Templates": {
      "ApprovalRequestDeletedHeading": "Hi there,",
      "ApprovalRequestDeletedLinkText": "View Inbox",
      "ApprovalRequestDeletedMessage": "This is a notification that {0} deleted the approval request containing {1}.",
      "ApprovalRequestDeletedSubject": "Approval request deleted",
      "ApprovalRequestReviewedHeading": "Hi there,",
      "ApprovalRequestReviewedLinkText": "View Sent Requests",
      "ApprovalRequestReviewedMessage": "This is a notification that {0} reviewed the approval request containing {1}.",
      "ApprovalRequestReviewedSubject": "Approval request reviewed",
      "ApprovalRequestSentHeading": "Hi there,",
      "ApprovalRequestSentLinkText": "View Inbox",
      "ApprovalRequestSentMessage": "This is a notification that {0} submitted an approval request containing {1}.",
      "ApprovalRequestSentSubject": "New approval request",
      "IdentityConfirmationHeading": "Hi there,",
      "IdentityConfirmationLinkText": "Confirm Email",
      "IdentityConfirmationMessage": "Thanks for creating a click2approve account. Please confirm your email address using the link below.",
      "IdentityConfirmationSubject": "Confirm your email for click2approve",
      "IdentityResetHeading": "Hi there,",
      "IdentityResetLinkText": "Reset Password",
      "IdentityResetMessage": "We received a request to reset your click2approve password. Use the link below.",
      "IdentityResetSubject": "Reset your click2approve password"
    },
    "Username": ""
  },
  "FileStorage": {
    "RootPath": "/filestorage"
  },
  "Hangfire": {
    "JobExpirationTimeoutMin": 30
  },
  "Identity": {
    "Lockout": {
      "AllowedForNewUsers": true,
      "LockoutTimeSpanInMinutes": 5,
      "MaxFailedAccessAttempts": 3
    },
    "Password": {
      "RequiredLength": 8
    }
  },
  "Limitations": {
    "MaxApprovalRequestsPerDay": 10,
    "MaxApproversPerRequest": 10,
    "MaxFiles": 100,
    "MaxFileSizeBytes": 4194304
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning"
    }
  },
  "UI": {
    "BaseUrl": "https://click2approve.com/ui"
  },
  "Urls": "http://*:5555"
